# Base URL of the backend service (no trailing slash, no /api suffix).
# Vite bakes this into the static bundle at build time.
#
# LOCAL DEV: Set this to your local backend URL (e.g., http://localhost:3001)
# PRODUCTION: Leave unset here; set via Netlify environment variables instead
# (Netlify will inject VITE_API_URL at build time)
VITE_API_URL=http://localhost:3001
