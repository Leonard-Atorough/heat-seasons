# Environment Variables
PORT=3001
NODE_ENV=development

# Database
# Local dev: SQLite file. Railway: file:/data/app.db (mounted volume).
# Swap provider to postgresql:// when migrating to Postgres — no code changes needed.
DATABASE_URL=file:./dev.db

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here # get this from Google Cloud Console when you set up your OAuth credentials
GOOGLE_CLIENT_SECRET=your_google_client_secret_here # also from Google Cloud Console. Create a new one if you haven't already.
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

FRONTEND_URL=http://localhost:3000
SESSION_SECRET=your_session_secret_here_change_in_production
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=24h

# Cookie settings
# COOKIE_SECURE: defaults to true in production, false in dev. Override to 'true'
#   when running behind a TLS proxy that terminates HTTPS (so NODE_ENV stays 'production'
#   but the server itself receives HTTP).
# COOKIE_DOMAIN: leave empty to bind cookies to the exact request hostname.
#   Set to '.yourdomain.com' (leading dot) to share cookies across subdomains.
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Logging
LOG_LEVEL=debug

# Note: CORS origin is controlled by FRONTEND_URL above — no separate CORS_ORIGIN var needed.
