# Environment Variables
PORT=3001
NODE_ENV=development

# Database
# Local dev: SQLite file. Railway: file:/data/app.db (mounted volume).
# Swap provider to postgresql:// when migrating to Postgres — no code changes needed.
DATABASE_URL=file:./dev.db

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

FRONTEND_URL=http://localhost:3000
SESSION_SECRET=your_session_secret_here_change_in_production
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=24h
COOKIE_DOMAIN=localhost

# Logging
LOG_LEVEL=debug

# Note: CORS origin is controlled by FRONTEND_URL above — no separate CORS_ORIGIN var needed.
